---
import site from "@/config/site";
import type { HeadProps } from "@/types";
import { withBasePath } from "@/utils/url";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

type Props = HeadProps;

const { title, description, image = site.ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImagePath = image.startsWith("/") ? withBasePath(image) : image;
---

<!-- Global Metadata -->
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={withBasePath("/favicon.svg")} />
  <link
    rel="icon"
    type="image/png"
    sizes="16x16"
    href={withBasePath("/favicon-16.png")}
  />
  <link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href={withBasePath("/favicon-32.png")}
  />

  <!-- Apple Touch Icon -->
  <link
    rel="apple-touch-icon"
    sizes="180x180"
    href={withBasePath("/apple-touch-icon.png")}
  />

  <!-- PWA Icons -->
  <link
    rel="icon"
    type="image/png"
    sizes="192x192"
    href={withBasePath("/icon-192.png")}
  />
  <link
    rel="icon"
    type="image/png"
    sizes="512x512"
    href={withBasePath("/icon-512.png")}
  />

  <!-- PWA Manifest -->
  <link rel="manifest" href={withBasePath("/manifest.json")} />

  <!-- Theme Color -->
  <meta name="theme-color" content="#3F9C87" />
  <meta name="msapplication-TileColor" content="#3F9C87" />

  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImagePath, Astro.url)} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta name="twitter:creator" content={`@${site.meta.author}`} />
  <meta name="twitter:image" content={new URL(ogImagePath, Astro.url)} />

  <!-- RSS Link -->
  <link
    rel="alternate"
    type="application/rss+xml"
    title={site.meta.title}
    href={new URL("rss.xml", Astro.site)}
  />

  <!-- canonical url -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Sitemap -->
  <link rel="sitemap" href={withBasePath("/sitemap-index.xml")} />

  <!-- pagefind -->
  <link href={withBasePath("/pagefind/pagefind-ui.css")} rel="stylesheet" />
  <script src={withBasePath("/pagefind/pagefind-ui.js")} is:inline></script>

  <!-- font  -->
  <Font cssVariable="--font-display" preload />

  <!-- View Transtions -->
  <ClientRouter />
</head>
